---
import Layout from "../layouts/Layout.astro"
import Hero from "../components/Hero.astro"
import LocaleSelector from "../components/LocaleSelector.astro"
import About from "../components/About.astro"
import Technologies from "../components/Technologies.astro"
import Experience from "../components/Experience.astro"
import Education from "../components/Education.astro"
import Projects from "../components/Projects.astro"

import { getI18N } from "../i18n"
const { copyrigth } = getI18N(Astro.currentLocale);
---

<Layout>
	<header class="max-w-[650px] mx-auto pt-5 md:pt-20 px-4">
		<Hero />
		<LocaleSelector />
	</header>
	<main class="max-w-[650px] mx-auto pb-5 px-4">
		<About />
		<Technologies />
		<Experience />
		<Education />
		<Projects />
	</main>
	<footer class="flex justify-center py-2 px-4">
		<p>&copy; 2024 Melchor Ruiz. { copyrigth }</p>
	</footer>
</Layout>
<script>
	let preferredLocale = localStorage.getItem('preferredLocale')
	if (!preferredLocale){
		preferredLocale = ['fr'].includes(navigator.language) ? navigator.language : 'es'
		localStorage.setItem('preferredLocale', preferredLocale)
	}
	const currentPath = window.location.pathname
	if (preferredLocale === 'es' && currentPath !== '/'){
		window.location.href = '/';
	} else if (preferredLocale === 'fr' && currentPath !== '/fr'){
		window.location.href = '/fr';
	}
</script>